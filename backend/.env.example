# OneWater Pakistan — Backend Environment Variables
# Copy this file to .env and fill in your real values before running

# ─── Database ─────────────────────────────────────────────────────────────────
# Your Supabase PostgreSQL connection string (Transaction Pooler recommended)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="REPLACE_WITH_A_LONG_RANDOM_SECRET_STRING_MIN_32_CHARS"

# ─── Admin Credentials (used only on FIRST startup to seed the admin user) ───
# After first run, change the password via the Admin Panel settings.
ADMIN_USERNAME="admin"
ADMIN_INITIAL_PASSWORD="OneWater@2026!"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL (in production). In dev, localhost:8080 is always allowed.
FRONTEND_URL="https://your-app.vercel.app"
